@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">MailSearch</h1>
    <p>Search and browse your imported emails.</p>
    <div class="d-flex justify-content-center gap-3 mt-4">
        <a asp-controller="Email" asp-action="Index" class="btn btn-primary btn-lg">Browse Emails</a>
        <a asp-controller="Email" asp-action="Search" class="btn btn-outline-primary btn-lg">Search Emails</a>
    </div>
</div>
