@model MailSearch.Web.Models.EmailDetailsViewModel
@{
    var email = Model.Email;
    ViewData["Title"] = email.Subject;

    string FormatAddress(MailSearch.Models.EmailAddress addr) =>
        addr.Name != null ? $"{addr.Name} <{addr.Email}>" : addr.Email;

    string FormatSize(long bytes) =>
        bytes < 1024 ? $"{bytes} B"
        : bytes < 1024 * 1024 ? $"{bytes / 1024.0:F1} KB"
        : $"{bytes / (1024.0 * 1024.0):F1} MB";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back to list</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h4 class="card-title">@email.Subject</h4>
        <dl class="row mb-0">
            <dt class="col-sm-2">From</dt>
            <dd class="col-sm-10">@FormatAddress(email.From)</dd>

            @if (email.To.Count > 0)
            {
                <dt class="col-sm-2">To</dt>
                <dd class="col-sm-10">@string.Join(", ", email.To.Select(FormatAddress))</dd>
            }
            @if (email.Cc.Count > 0)
            {
                <dt class="col-sm-2">CC</dt>
                <dd class="col-sm-10">@string.Join(", ", email.Cc.Select(FormatAddress))</dd>
            }
            @if (email.Bcc.Count > 0)
            {
                <dt class="col-sm-2">BCC</dt>
                <dd class="col-sm-10">@string.Join(", ", email.Bcc.Select(FormatAddress))</dd>
            }
            @if (email.Date.HasValue)
            {
                <dt class="col-sm-2">Date</dt>
                <dd class="col-sm-10">@email.Date.Value.ToLocalTime()</dd>
            }
            @if (!string.IsNullOrEmpty(email.FolderPath))
            {
                <dt class="col-sm-2">Folder</dt>
                <dd class="col-sm-10">@email.FolderPath</dd>
            }
        </dl>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Tags</strong>
    </div>
    <div class="card-body">
        @if (Model.Tags.Count > 0)
        {
            <div class="d-flex flex-wrap gap-2 mb-2">
                @foreach (var tag in Model.Tags)
                {
                    <span class="badge bg-primary d-flex align-items-center gap-1">
                        @tag.Name
                        <form asp-action="RemoveTag" method="post" class="d-inline m-0 p-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@email.Id" />
                            <input type="hidden" name="tagName" value="@tag.Name" />
                            <button type="submit" class="btn-close btn-close-white" aria-label="Remove tag" style="font-size:0.6rem"></button>
                        </form>
                    </span>
                }
            </div>
        }
        <form asp-action="AddTag" method="post" class="d-flex gap-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@email.Id" />
            <input type="text" name="tagName" class="form-control form-control-sm" placeholder="Add tag…" style="max-width:200px" />
            <button type="submit" class="btn btn-sm btn-outline-primary">Add</button>
        </form>
    </div>
</div>

@if (Model.Attachments.Count > 0)
{
    <div class="card mb-3">
        <div class="card-header"><strong>Attachments (@Model.Attachments.Count)</strong></div>
        <ul class="list-group list-group-flush">
            @foreach (var att in Model.Attachments)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span>@att.Filename</span>
                    <span class="text-muted small">@FormatSize(att.Size)</span>
                </li>
            }
        </ul>
    </div>
}

@if (!string.IsNullOrEmpty(email.BodyText))
{
    <div class="card">
        <div class="card-header"><strong>Body</strong></div>
        <div class="card-body">
            <pre class="mb-0" style="white-space:pre-wrap;word-break:break-word;max-height:600px;overflow-y:auto">@email.BodyText</pre>
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(email.BodyHtml))
{
    <div class="card">
        <div class="card-header"><strong>Body (HTML)</strong></div>
        <div class="card-body">
            <iframe srcdoc="@email.BodyHtml" sandbox="" style="width:100%;height:600px;border:none"></iframe>
        </div>
    </div>
}
