@model MailSearch.Web.Models.ImportViewModel
@{
    ViewData["Title"] = "Import Outlook File";
}

<h2>Import Outlook File</h2>
<p class="text-muted">Upload a <code>.msg</code> file to import it into the database.</p>

@if (Model.Success == true)
{
    <div class="alert alert-success">@Model.Message</div>
    <a asp-controller="Email" asp-action="Index" class="btn btn-primary mb-3">Browse Emails</a>
}
else if (Model.IsError)
{
    <div class="alert alert-danger">@Model.Message</div>
}
else if (Model.Success == false)
{
    <div class="alert alert-warning">@Model.Message</div>
}

<form method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label for="file" class="form-label">Outlook message file (.msg)</label>
        <input type="file" id="file" name="file" class="form-control" accept=".msg" required />
    </div>
    <button type="submit" class="btn btn-primary">Import</button>
</form>
