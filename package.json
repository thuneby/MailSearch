{
  "name": "mailsearch",
  "version": "1.0.0",
  "description": "Read Outlook files, store metadata/content/attachments, and search emails",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mailsearch": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "clean": "rimraf dist"
  },
  "keywords": [
    "outlook",
    "pst",
    "msg",
    "email",
    "search",
    "organizer"
  ],
  "author": "John Thuneby",
  "license": "MIT",
  "dependencies": {
    "@kenjiuno/msgreader": "^1.10.1",
    "better-sqlite3": "^11.9.1",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "pst-extractor": "^1.9.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
